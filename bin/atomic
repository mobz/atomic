#!/usr/bin/env bash
set -euo pipefail

ATOMIC_DIR="atomic"
SPECS_DIR="specs"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

source "$SCRIPT_DIR/lib/helpers.sh"
source "$SCRIPT_DIR/lib/atomic-status"
source "$SCRIPT_DIR/lib/atomic-advance"
source "$SCRIPT_DIR/lib/atomic-reset"
source "$SCRIPT_DIR/lib/atomic-show-spec"
source "$SCRIPT_DIR/lib/atomic-show-context"
source "$SCRIPT_DIR/lib/atomic-merge-specs"
source "$SCRIPT_DIR/lib/atomic-commit"
source "$SCRIPT_DIR/lib/atomic-push"
source "$SCRIPT_DIR/lib/atomic-clean"
source "$SCRIPT_DIR/lib/atomic-help"

# ── dispatch ──────────────────────────────────────────────────────────────────

JSON_OUTPUT="false"
CMD=""
ARGS=()

for arg in "$@"; do
  case "$arg" in
    --json) JSON_OUTPUT="true" ;;
    -*) ;;
    *) if [[ -z "$CMD" ]]; then CMD="$arg"; else ARGS+=("$arg"); fi ;;
  esac
done

case "${CMD:-help}" in
  status)       cmd_status ;;
  advance)      cmd_advance "${ARGS[0]:-}" ;;
  reset)        cmd_reset ;;
  show-spec)    cmd_show_spec ;;
  show-context) cmd_show_context ;;
  merge-specs)  cmd_merge_specs ;;
  commit)       cmd_commit ;;
  push)         cmd_push ;;
  clean)        cmd_clean ;;
  help|--help)  cmd_help ;;
  *)            echo "{\"error\":\"unknown command: $CMD\"}" >&2; exit 1 ;;
esac
